{
	"name": "@template/api",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"exports": {
		".": "./src/index.ts",
		"./router": "./src/router.ts"
	},
	"scripts": {
		"dev": "bun --hot run src/index.ts",
		"build": "bun build ./src/index.ts --target=bun --outdir=dist --minify",
		"start": "bun run dist/index.js",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@t3-oss/env-core": "0.13.11",
		"@template/shared": "workspace:*",
		"@trpc/server": "11.17.0",
		"hono": "4.12.16",
		"zod": "4.4.1"
	},
	"devDependencies": {
		"bun-types": "1.3.13"
	}
}
