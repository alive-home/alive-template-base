{
  "name": "@template/api",
  "version": "0.0.0",
  "dependencies": {
    "@t3-oss/env-core": "0.13.11",
    "@template/shared": "workspace:*",
    "@trpc/server": "11.18.0",
    "hono": "4.12.28",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "bun-types": "1.3.14"
  },
  "exports": {
    ".": "./src/index.ts",
    "./router": "./src/router.ts"
  },
  "private": true,
  "scripts": {
    "build": "bun build ./src/index.ts --target=bun --outdir=dist --minify",
    "dev": "bun --hot run src/index.ts",
    "start": "bun run dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "type": "module"
}
