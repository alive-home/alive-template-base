# Public origins — both apps consume both values.
# API: used by api for CORS and for issuing absolute URLs.
# WEB: used by web (via VITE_*) for the tRPC and auth client.
API_BASE_URL=http://localhost:3001
WEB_BASE_URL=http://localhost:3000

# Vite-exposed copies for the browser bundle.
#
# VITE_API_BASE_URL: leave UNSET (or empty) when web's nginx proxies
# /trpc to the api container — the tRPC client falls back to "/trpc"
# (same-origin), which is what production / the Alive deploy default
# expects. Set to an absolute URL only for split-port local dev.
VITE_API_BASE_URL=http://localhost:3001
VITE_WEB_BASE_URL=http://localhost:3000

# Auth — used both as login password and as JWT signing key.
# Generate with: openssl rand -base64 32
AUTH_SECRET=replace-me-with-32-bytes
