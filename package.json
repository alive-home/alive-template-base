{
  "name": "alive-template-base",
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@types/node": "26.1.1",
    "bun-types": "1.3.14",
    "syncpack": "15.3.2",
    "turbo": "2.10.4",
    "typescript": "7.0.2"
  },
  "engines": {
    "bun": ">=1.2.0"
  },
  "packageManager": "bun@1.3.11",
  "private": true,
  "scripts": {
    "build": "bun --env-file=.env turbo run build",
    "check": "bun run lint && bun run typecheck",
    "dev": "bun --env-file=.env turbo run dev",
    "dev:local": "scripts/runtime/local.sh",
    "docker:build": "docker buildx bake -f docker-bake.hcl",
    "docker:push": "docker buildx bake -f docker-bake.hcl --push",
    "format": "biome format --write .",
    "lint": "biome check . && bun run lint:file-length",
    "lint:file-length": "scripts/check-file-length.sh",
    "lint:fix": "biome check --write .",
    "test:e2e": "bun --filter e2e test",
    "typecheck": "turbo run typecheck"
  },
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*",
    "e2e"
  ]
}
