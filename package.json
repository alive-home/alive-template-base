{
	"name": "alive-template-base",
	"private": true,
	"type": "module",
	"workspaces": [
		"apps/*",
		"packages/*",
		"e2e"
	],
	"scripts": {
		"dev": "bun --env-file=.env turbo run dev",
		"dev:local": "scripts/runtime/local.sh",
		"build": "bun --env-file=.env turbo run build",
		"lint": "biome check .",
		"format": "biome format --write .",
		"typecheck": "turbo run typecheck",
		"test:e2e": "bun --filter e2e test",
		"docker:build": "docker buildx bake -f docker-bake.hcl",
		"docker:push": "docker buildx bake -f docker-bake.hcl --push"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.13",
		"@types/node": "25.6.0",
		"bun-types": "1.3.13",
		"syncpack": "14.3.1",
		"turbo": "2.9.17",
		"typescript": "6.0.3"
	},
	"packageManager": "bun@1.3.11",
	"engines": {
		"bun": ">=1.2.0"
	}
}
